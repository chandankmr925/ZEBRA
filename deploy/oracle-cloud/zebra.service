[Unit]
Description=ZEBRA Algorithmic Screener
After=network.target

[Service]
Type=simple
User=zebra
Group=zebra
WorkingDirectory=/opt/zebra
EnvironmentFile=/etc/zebra/zebra.env
ExecStart=/usr/bin/node server.js
Restart=on-failure
RestartSec=5

# Hardening (optional)
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
